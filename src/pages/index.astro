---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hotdogImages } from '../data/hotdogImages.js';
---

<BaseLayout
	title="Richard Gill's Hot Dog World Tour"
	description="Join Richard Gill on a Hot Dog World Tour! A photo gallery of hot dogs enjoyed in cities around the world, from Las Vegas to Berlin, Barcelona to Iceland."
>
	<header class="text-center mb-8">
		<img
			src="/images/thumbs/sm/hotdoglogo.webp"
			alt="Hot Dog World Tour Logo"
			width="404"
			height="352"
			class="max-w-[200px] w-[200px] h-auto mx-auto mb-4"
			fetchpriority="high"
		/>
		<p class="max-w-[600px] mx-auto text-lg leading-relaxed text-gray-300">
			I love Hot Dogs! I hope you enjoy looking at my Hot Dogs from around the world as much as I have enjoyed
			traveling and eating them.
		</p>
	</header>

	<main class="mb-8">
		<div class="masonry" id="gallery"></div>

		<!-- Lightbox -->
		<div class="hidden fixed inset-0 bg-black/95 z-[1000] justify-center items-center flex-col" id="lightbox">
			<button class="absolute top-4 right-6 text-white text-4xl cursor-pointer bg-none border-none z-[1001] hover:text-red-500" id="lightbox-close">
				&times;
			</button>
			<button class="absolute top-1/2 left-4 text-white text-4xl cursor-pointer bg-none border-none z-[1001] hover:text-red-500 -translate-y-1/2" id="lightbox-prev">
				&#8249;
			</button>
			<button class="absolute top-1/2 right-4 text-white text-4xl cursor-pointer bg-none border-none z-[1001] hover:text-red-500 -translate-y-1/2" id="lightbox-next">
				&#8250;
			</button>
			<div class="flex flex-col items-center max-w-[90vw] max-h-[80vh]">
				<img
					id="lightbox-img"
					src=""
					alt=""
					class="max-w-[90vw] max-h-[70vh] object-contain rounded"
				/>
				<div class="text-center mt-4 max-w-[600px]">
					<h2 id="lightbox-title" class="text-2xl mb-2"></h2>
					<p id="lightbox-desc" class="text-lg text-gray-400 leading-relaxed"></p>
				</div>
			</div>
			<div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-gray-600 text-sm" id="lightbox-counter"></div>
		</div>
	</main>

	<div class="text-center">
		<a href="/map" class="inline-block mt-3 text-red-400 no-underline text-sm hover:underline">
			🗺️ View Interactive Map
		</a>
	</div>

	<script define:vars={{ images: hotdogImages }}>
		const hotdogImages = images;

		// Build gallery
		const gallery = document.getElementById('gallery');
		const lightbox = document.getElementById('lightbox');
		const lightboxImg = document.getElementById('lightbox-img');
		const lightboxTitle = document.getElementById('lightbox-title');
		const lightboxDesc = document.getElementById('lightbox-desc');
		const lightboxCounter = document.getElementById('lightbox-counter');
		const lightboxClose = document.getElementById('lightbox-close');
		const lightboxPrev = document.getElementById('lightbox-prev');
		const lightboxNext = document.getElementById('lightbox-next');

		let currentIndex = 0;
		const loaded = {};
		const eagerLoadCount = 5;

		// Create gallery items
		hotdogImages.forEach((img, index) => {
			const item = document.createElement('div');
			item.className =
				'break-inside-avoid mb-4 cursor-pointer relative overflow-hidden rounded loading';
			item.dataset.index = index;

			const image = document.createElement('img');
			image.src = `/images/thumbs/${img.file}`;
			image.srcset = `/images/thumbs/sm/${img.file} 500w, /images/thumbs/${img.file} 800w`;
			image.sizes = '(max-width: 500px) 100vw, (max-width: 900px) 50vw, 33vw';
			image.alt = img.title;
			image.className = 'w-full h-auto block rounded transition-transform duration-300 hover:scale-103';
			image.loading = index < eagerLoadCount ? 'eager' : 'lazy';
			image.width = img.width;
			image.height = img.height;

			// Load event - toggle skeleton
			image.addEventListener('load', () => {
				item.classList.remove('loading');
				item.classList.add('loaded');
				loaded[index] = true;
			});

			const overlay = document.createElement('div');
			overlay.className = 'overlay';
			overlay.innerHTML = `<h3>${img.title}</h3><p>${img.description}</p>`;

			item.appendChild(image);
			item.appendChild(overlay);
			item.addEventListener('click', () => openLightbox(index));
			gallery.appendChild(item);
		});

		// Lightbox functions
		function openLightbox(index) {
			currentIndex = index;
			updateLightbox();
			lightbox.classList.remove('hidden');
			lightbox.classList.add('flex');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			lightbox.classList.add('hidden');
			lightbox.classList.remove('flex');
			document.body.style.overflow = '';
		}

		function updateLightbox() {
			const img = hotdogImages[currentIndex];
			lightboxImg.src = `/images/${img.file}`;
			lightboxImg.alt = img.title;
			lightboxTitle.textContent = img.title;
			lightboxDesc.textContent = img.description;
			lightboxCounter.textContent = `${currentIndex + 1} / ${hotdogImages.length}`;
		}

		function nextImage() {
			currentIndex = (currentIndex + 1) % hotdogImages.length;
			updateLightbox();
		}

		function prevImage() {
			currentIndex = (currentIndex - 1 + hotdogImages.length) % hotdogImages.length;
			updateLightbox();
		}

		// Event listeners
		lightboxClose.addEventListener('click', closeLightbox);
		lightboxNext.addEventListener('click', nextImage);
		lightboxPrev.addEventListener('click', prevImage);

		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox) closeLightbox();
		});

		// Keyboard controls
		document.addEventListener('keydown', (e) => {
			if (lightbox.classList.contains('hidden')) return;
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowRight') nextImage();
			if (e.key === 'ArrowLeft') prevImage();
		});
	</script>

	<style is:global>
		.loading {
			background: #2a2a2a;
			min-height: 200px;
		}

		.loading img {
			opacity: 0;
		}

		.loading.shimmer {
			min-height: 200px;
		}

		.loaded {
			background: none;
			min-height: 0;
		}

		.loaded img {
			opacity: 1;
			transition: opacity 0.3s ease;
		}

		.hover\:scale-103:hover {
			transform: scale(1.03);
		}

		.overlay {
			position: absolute;
			bottom: 0;
			left: 0;
			right: 0;
			background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
			padding: 2rem 0.75rem 0.75rem;
			opacity: 0;
			transition: opacity 0.3s ease;
		}

		.overlay h3 {
			font-size: 0.95rem;
			font-weight: 600;
			color: #fff;
			margin-bottom: 0.25rem;
		}

		.overlay p {
			font-size: 0.8rem;
			color: #ccc;
			line-height: 1.4;
		}

		.break-inside-avoid:hover .overlay {
			opacity: 1;
		}
	</style>
</BaseLayout>
