---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hotdogImages } from '../data/hotdogImages.js';

const imagesWithCoords = hotdogImages.filter((img) => img.lat);
const imagesJson = JSON.stringify(imagesWithCoords);
---

<BaseLayout title="Richard Gill — CV" description="CV of Richard Gill — Engineering Manager with 16 years of commercial experience in web development and team leadership.">
	<style>
		.cv {
			max-width: 42rem;
			margin: 0 auto;
		}

		.cv-header {
			border-bottom: 2px solid #f44;
			padding-bottom: 1.5rem;
			margin-bottom: 2rem;
		}

		.cv-header h1 {
			font-size: 2.25rem;
			font-weight: 700;
			margin-bottom: 0.75rem;
		}

		.cv-contact {
			display: flex;
			flex-wrap: wrap;
			gap: 2rem;
			color: #aaa;
			font-size: 0.875rem;
		}

		.cv-contact a {
			color: #f44;
			text-decoration: none;
		}

		.cv-contact a:hover {
			text-decoration: underline;
		}

		.cv-section {
			margin-bottom: 2.5rem;
		}

		.cv-section h2 {
			font-size: 0.875rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.125rem;
			color: #f44;
			border-bottom: 1px solid #444;
			padding-bottom: 0.25rem;
			margin-bottom: 1.25rem;
		}

		.cv-job {
			margin-bottom: 1.75rem;
		}

		.cv-job-header {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			flex-wrap: wrap;
			gap: 0.25rem;
			margin-bottom: 0.5rem;
		}

		.cv-job-title {
			font-size: 1.05rem;
			font-weight: 600;
		}

		.cv-job-company {
			color: #aaa;
			font-size: 0.875rem;
		}

		.cv-job-dates {
			color: #666;
			font-size: 0.875rem;
			white-space: nowrap;
		}

		.cv-job p {
			color: #ccc;
			font-size: 0.9375rem;
			line-height: 1.75;
		}

		.cv-profile p {
			color: #ccc;
			font-size: 0.9375rem;
			line-height: 1.75;
			margin-bottom: 0.75rem;
		}

		.cv-skills {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 0.5rem;
		}

		.cv-skills li {
			list-style: none;
			color: #ccc;
			font-size: 0.9375rem;
			padding-left: 1rem;
			position: relative;
		}

		.cv-skills li::before {
			content: '—';
			position: absolute;
			left: 0;
			color: #f44;
		}

		.cv-edu {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			flex-wrap: wrap;
			gap: 0.25rem;
			margin-bottom: 0.75rem;
		}

		.cv-edu-details {
			color: #ccc;
			font-size: 0.9375rem;
		}

		.cv-edu-dates {
			color: #666;
			font-size: 0.875rem;
			white-space: nowrap;
		}

		.cv-edu-note {
			width: 100%;
			color: #666;
			font-size: 0.825rem;
		}

		.cv-interests p {
			color: #ccc;
			font-size: 0.9375rem;
			line-height: 1.75;
			margin-bottom: 0.5rem;
		}

		.hotdog-banner {
			width: 100%;
			max-height: 300px;
			object-fit: cover;
			object-position: center;
			border-radius: 6px;
			margin-bottom: 2rem;
			display: block;
		}

		@media print {
			body {
				background: #fff;
				color: #000;
				padding: 0;
			}

			.no-print {
				display: none;
			}

			.cv-section h2 {
				color: #c00;
				border-color: #ccc;
			}

			.cv-header {
				border-color: #c00;
			}

			.cv-contact a {
				color: #c00;
			}

			.cv-job p,
			.cv-profile p,
			.cv-interests p,
			.cv-edu-details,
			.cv-skills li {
				color: #333;
			}

			.cv-job-company,
			.cv-job-dates,
			.cv-edu-dates,
			.cv-edu-note {
				color: #666;
			}

			.cv-skills li::before {
				color: #c00;
			}
		}
	</style>

	<div class="cv">
		<img id="hotdog-banner" class="hotdog-banner" src="" alt="" width="1024" height="300" />

		<header class="cv-header">
			<h1>Richard Gill</h1>
			<div class="cv-contact">
				<span>07519 878764</span>
				<a href="mailto:richard.gill1986@gmail.com">richard.gill1986@gmail.com</a>
				<a href="https://www.linkedin.com/in/richard-gill-56bb5347/" target="_blank" rel="noopener">LinkedIn</a>
				<a href="https://open.spotify.com/playlist/5mRht3M1cXxPNn3EGQjlcn?si=2KP5ZGMMQg610pw-S0hpyg" target="_blank" rel="noopener">Spotify</a>
			</div>
		</header>

		<section class="cv-section cv-profile">
			<h2>Personal Profile</h2>
			<p>
				I am a highly motivated and passionate person with sixteen years' experience in the commercial industry. I
				have worked for The Hut Group (THG) for the last fourteen years, working my way up through various development
				roles. For the last year I have been Head of Development for their Nutrition websites Myprotein.com and Myvitamins.com.
			</p>
			<p>
				My knowledge and skills have developed considerably during my time at THG, with experience across a range of
				web technologies and programming languages. I have also attended several internal training schemes
				which have helped develop my interpersonal and professional management skills.
			</p>
			<p>
				After fourteen years at THG I have learnt to be a very resilient manager. I manage my stress through regular
				4:30am gym sessions and spending time with my family. I have a flexible working approach and will always go
				above and beyond. I am motivated by results and delivery. My values are to lead by example, teamwork,
				accountability, empathy, honesty and trust.
			</p>
		</section>

		<section class="cv-section">
			<h2>Experience</h2>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">Head of Engineering <span class="cv-job-company">— Myprotein, THG PLC</span></span>
					<span class="cv-job-dates">May 2025 – Present</span>
				</div>
				<p>
					
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">Engineering Manager – Nutrition <span class="cv-job-company">— THG</span></span>
					<span class="cv-job-dates">Jan 2024 – May 2025</span>
				</div>
				<p>
					Led the fully remote THG Nutrition tech squad. Under my leadership the team delivered a fully functioning
					platform in the first 3 months of forming, worked closely with PWC and their in-house design team for 6
					weeks to deliver new templates for MP.com, smoothly migrated the 3 highest-revenue locales (com, Germany and
					Japan) onto the new platform without issues or downtime, and delivered a new Nutrition-specific product page
					alongside many other BAU changes. Worked directly with senior leadership, CRO and UX to push the platform
					forward with core web vitals at heart, resulting in faster websites with improved user experience. During Q1
					2025, migrated all 64 Nutrition websites (Myprotein, Myvitamins and Myvegan) onto the Altitude platform.
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">Engineering Manager <span class="cv-job-company">— THG</span></span>
					<span class="cv-job-dates">May 2021 – Dec 2024</span>
				</div>
				<p>
					Managed a team of 10 software engineers with 2 lead engineers reporting directly to me. Provided 360 feedback,
					managed team performance and development, and was responsible for site builds and BAU workstreams. In 2021 we
					delivered 134 websites between two teams — 81 delivered by my team alone. Used data from JIRA to analyse team
					efficiency and sprint progress, providing feedback to engineers to promote self-development. During the pandemic
					we adopted a remote working model and maintained high throughput throughout, taking on 6 new staff members whom
					I was actively involved in interviewing, inducting and mentoring. Worked closely with Project Managers, Account
					Directors, UX Designers and Trading Teams to ensure every client deadline was met. Won Tech Team of the Year in
					2021. Also recently completed my Scrum Master certification in my own time.
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">Tech Lead <span class="cv-job-company">— THG</span></span>
					<span class="cv-job-dates">March 2017 – May 2021</span>
				</div>
				<p>
					Responsible for a team of up to 11 full-time employees and a small number of interns, running four parallel
					workstreams. Acted as Manager, Scrum Master, Developer and Mentor across a range of agile methodologies.
					Focused increasingly on the management side — conducting regular one-to-ones to develop, support and motivate
					the team.
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">International Rollout Lead <span class="cv-job-company">— THG</span></span>
					<span class="cv-job-dates">Oct 2016 – March 2017</span>
				</div>
				<p>
					Led THG's expansion into international territories, directing the development of over 50 international websites
					across 28 different languages. Worked closely with representatives from each business division to plan, develop
					and deliver the project. Nominated as Team of the Year at the end of 2016, and personally nominated for Tech
					Employee of the Year.
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">Front End Web Developer <span class="cv-job-company">— THG</span></span>
					<span class="cv-job-dates">2012 – Nov 2016</span>
				</div>
				<p>
					Joined THG as a Front End Developer when the team had 8 developers maintaining 30 websites. As THG more than
					doubled in size those 30 websites grew to over 100, and I grew with the company.
				</p>
			</div>

			<div class="cv-job">
				<div class="cv-job-header">
					<span class="cv-job-title">UI Designer / Developer progression <span class="cv-job-company">— Martin Dawes Systems</span></span>
					<span class="cv-job-dates">Sept 2007 – Nov 2012</span>
				</div>
				<p>
					Progressed through a series of roles: Web Designer (2007–2008), Graduation Scheme (2008–2009), UI Designer
					(2009–2011), UI Designer / Developer (2011–2012).
				</p>
			</div>
		</section>

		<section class="cv-section">
			<h2>Skills</h2>
			<ul class="cv-skills">
				<li>Jira and workflow management</li>
				<li>Scrum and other agile techniques</li>
				<li>Good organisational and time management skills</li>
				<li>Good presentation skills using a variety of media</li>
				<li>Excellent interpersonal skills</li>
				<li>Excellent work ethic</li>
				<li>Excellent attention to detail</li>
				<li>Working independently or as part of a team</li>
				<li>Ability to work under pressure and to tight deadlines</li>
				<li>Willingness to work flexibly</li>
			</ul>
		</section>

		<section class="cv-section">
			<h2>Education</h2>

			<div class="cv-edu">
				<span class="cv-edu-details">BA (Hons) Digital Arts — Liverpool John Moores University</span>
				<span class="cv-edu-dates">2006 – 2007</span>
				<span class="cv-edu-note">via St Helens College</span>
			</div>

			<div class="cv-edu">
				<span class="cv-edu-details"
					>Foundation Degree in Arts (Multimedia Arts and Animation) — Liverpool John Moores University</span
				>
				<span class="cv-edu-dates">2004 – 2006</span>
				<span class="cv-edu-note">via St Helens College</span>
			</div>
		</section>

		<section class="cv-section cv-interests">
			<h2>Interests</h2>
			<p>
				I am a dedicated family man and love spending time with my wife and two children. We enjoy snowboarding,
				skateboarding, camping and the beach.
			</p>
			<p>
				I am interested in all aspects of new technology, games platforms and computer software, and am enthusiastic
				about maintaining a healthy lifestyle through regular gym training. I also have a keen interest in travel and
				movies.
			</p>
		</section>

		<section class="cv-section">
			<h2>References</h2>
			<p style="color: #ccc; font-size: 0.9375rem;">Available upon request.</p>
		</section>
	</div>

	<div class="text-center mt-8 no-print">
		<a href="/" class="inline-block text-red-400 no-underline text-sm hover:underline">← Back to Hot Dog World Tour</a>
	</div>

	<script define:vars={{ images: imagesJson }}>
		const imagesData = JSON.parse(images);
		const pick = imagesData[Math.floor(Math.random() * imagesData.length)];
		const banner = document.getElementById('hotdog-banner');
		banner.src = '/images/' + pick.file;
		banner.alt = pick.title;
		banner.width = pick.width;
		banner.height = pick.height;
	</script>
</BaseLayout>
